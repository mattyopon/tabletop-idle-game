{
  "name": "tabletop-idle-game",
  "version": "1.0.0",
  "description": "Tabletop Adventure Story: Idle Cozy Time - A desktop resident idle game / 卓上冒険物語：放置ほっこりタイム",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win --x64",
    "test": "echo \"No tests yet\" && exit 0"
  },
  "build": {
    "appId": "com.mattyopon.tabletop-idle-game",
    "productName": "卓上冒険物語",
    "win": {
      "target": "portable",
      "icon": null
    },
    "files": [
      "main.js",
      "preload.js",
      "renderer/**/*"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "keywords": [
    "electron",
    "idle-game",
    "pixel-art",
    "desktop-pet"
  ],
  "author": "Yutaro Maeda",
  "license": "MIT",
  "devDependencies": {
    "electron": "^41.0.0",
    "electron-builder": "^26.8.1"
  }
}
